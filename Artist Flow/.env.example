# Firebase client configuration (from Firebase Console > Project settings > Your apps > Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional: set when frontend is hosted outside Firebase and should call a full feedback API URL.
# Example: https://us-central1-artist-flow-prod.cloudfunctions.net/sendFeedback
VITE_FEEDBACK_ENDPOINT=

# Email automation via Firebase Functions + Resend (set with firebase-tools functions:params:set)
RESEND_API_KEY=
FEEDBACK_TO_EMAIL=
FEEDBACK_FROM_EMAIL=onboarding@resend.dev
