rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isParticipant() {
      return signedIn() && (
        resource.data.artistId == request.auth.uid ||
        resource.data.venueId == request.auth.uid
      );
    }

    function isParticipantInRequest() {
      return signedIn() && (
        request.resource.data.artistId == request.auth.uid ||
        request.resource.data.venueId == request.auth.uid
      );
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /opportunities/{opportunityId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.venueId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.venueId == request.auth.uid;
    }

    match /connections/{connectionId} {
      allow read: if isParticipant();
      allow create: if isParticipantInRequest();
      allow update: if isParticipant();
      allow delete: if false;

      match /messages/{messageId} {
        function parentConnection() {
          return get(/databases/$(database)/documents/connections/$(connectionId));
        }

        function parentParticipant() {
          return signedIn() && (
            parentConnection().data.artistId == request.auth.uid ||
            parentConnection().data.venueId == request.auth.uid
          );
        }

        allow read: if parentParticipant();
        allow create: if parentParticipant() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
